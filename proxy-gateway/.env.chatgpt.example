# ── ChatGPT gateway (deploy on chatgpt1.genzdigitalstore.com) ─────────────────
# Copy to .env on the ChatGPT gateway app and fill the secrets. Same generic
# proxy-gateway/server.js as HIX / BypassGPT — only this .env differs.

PORT=3000
TOOL_KEY=chatgpt
TOOL_NAME=ChatGPT

TARGET_ORIGIN=https://chatgpt.com
# ChatGPT's app lives at the root; a client lease lands straight in the chat UI.
DEFAULT_PATH=/
# Where an admin CAPTURE lease lands to log in fresh and save a session to the vault.
SIGNIN_PATH=/auth/login

GATEWAY_PUBLIC_ORIGIN=https://chatgpt1.genzdigitalstore.com
API_BASE=https://api.genzdigitalstore.com/api/crm/proxy/gateway

# MUST match the backend values exactly (copy from the API app's .env, or from the
# existing hix-gateway/.env — every proxy tool shares ONE pair of proxy secrets):
LEASE_SECRET=__SET_TO_BACKEND_PROXY_LEASE_SECRET__
GATEWAY_KEY=__SET_TO_BACKEND_PROXY_GATEWAY_KEY__

# ── ChatGPT-specific notes ────────────────────────────────────────────────────
# • Streaming: chat replies stream as text/event-stream from /backend-api/conversation.
#   The gateway pipes event-streams through untouched, so streaming chat works.
# • Cloudflare: chatgpt.com sits behind Cloudflare + Arkose. The gateway pins a fixed
#   browser UA + client-hints (matching the backend verifier) so a cf_clearance cookie
#   captured in the vault stays valid. Capture the session THROUGH this gateway (admin
#   "Refresh Through Proxy") so cf_clearance is minted in the same context it's used.
# • Assets load from the public CDN cdn.oaistatic.com cross-origin (no auth needed);
#   the gateway strips the page CSP so they load directly. Only set ASSET_ORIGINS if a
#   future asset host needs same-origin proxying, e.g.:
#   ASSET_ORIGINS=https://cdn.oaistatic.com
# • Keep IDENTITY_SHIELD UNSET (off): ChatGPT is a token SPA (next-auth) and redacting
#   /api/auth/session logs it out / renders blank. Account/email/plan hiding is done by
#   the injected overlay (overlay.js) client-side instead.
