# ── Ryne AI gateway (deploy on ryne1.genzdigitalstore.com) ────────────────────
# Copy to .env on the Ryne AI gateway app and fill the secrets. Same generic
# proxy-gateway/server.js as the other tools — only this .env differs.

PORT=3000
TOOL_KEY=ryne
TOOL_NAME=Ryne AI

TARGET_ORIGIN=https://ryne.ai
# Ryne's logged-in app/editor lives at /dashboard (tools at /pages/humanizer, etc).
DEFAULT_PATH=/dashboard
# Where an admin CAPTURE lease lands to log in fresh and save a session to the vault.
SIGNIN_PATH=/signup

GATEWAY_PUBLIC_ORIGIN=https://ryne1.genzdigitalstore.com
API_BASE=https://api.genzdigitalstore.com/api/crm/proxy/gateway

# MUST match the backend values exactly (same shared pair as the other proxy tools —
# copy from the API app's .env or any existing proxy gateway's env vars):
LEASE_SECRET=__SET_TO_BACKEND_PROXY_LEASE_SECRET__
GATEWAY_KEY=__SET_TO_BACKEND_PROXY_GATEWAY_KEY__

# If Ryne serves CSS/JS from a separate CDN/asset host that fails to load cross-origin,
# proxy it same-origin through the gateway, e.g.:
# ASSET_ORIGINS=https://cdn.ryne.ai
# Keep IDENTITY_SHIELD unset unless proven auth-safe (it can log token SPAs out).

# ── Account/logout shield (per-tool) ──────────────────────────────────────────
# ACCOUNT_SHIELD is ON by default: logout is never proxied (it would kill the shared
# vault session), and account/billing/subscription/settings PAGE loads show a friendly
# "managed by Gen Z" notice while their billing APIs are stubbed. This is auth-safe and
# does NOT redact session JSON. Set ACCOUNT_SHIELD=0 only if a tool's working area lives
# under one of those path words (prefer NAV_BLOCK_EXCLUDE to carve out just that path).
#   NAV_BLOCK_EXCLUDE=/settings/editor        # don't block this working-area path
#   NAV_BLOCK_EXTRA=/manage-account,/wallet   # also block these tool-specific paths
# HIDE_SELECTORS: comma-separated EXACT CSS selectors for this tool's account/top-bar/
# avatar containers (shipped in the critical hide CSS before first paint + to overlay.js).
# NEVER include the editor / chat / upload / result area. Example:
#   HIDE_SELECTORS=header .user-menu, aside .account-card

# ── Session-expired / public-page protection (WriteHuman & Ryne) ──────────────
# This tool serves its PUBLIC "Log in / Sign Up" page at the default path with HTTP 200
# when the vault session is dead (no redirect to /sign-in), which is why an expired
# account showed the public page instead of the tool. DETECT_LOGGED_OUT=1 makes the
# gateway: if account cookies WERE attached but the main page still shows a logged-out
# shell (sign-in AND sign-up CTA, NO logout/account control), flag the account
# session-expired server-side and show a friendly "session expired" page instead of the
# public page. The backend verifier does the same at save/verify time (tools.js
# detectLoggedOut), so admin sees "session expired / needs login". Leave ON for this tool.
DETECT_LOGGED_OUT=1
# Account/profile/billing/logout HIDING + route blocking is already provided by the
# shared ACCOUNT_SHIELD (default ON) — no extra config needed. Only set HIDE_SELECTORS
# if this tool wraps its account/top-bar in an obfuscated class the generic rules miss:
#   HIDE_SELECTORS=header .user-menu, aside .account
