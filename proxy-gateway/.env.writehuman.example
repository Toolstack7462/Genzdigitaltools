# ── WriteHuman gateway (deploy on writehuman1.genzdigitalstore.com) ───────────
# Copy to .env on the WriteHuman gateway app and fill the secrets. Same generic
# proxy-gateway/server.js as the other tools — only this .env differs.

PORT=3000
TOOL_KEY=writehuman
TOOL_NAME=WriteHuman

TARGET_ORIGIN=https://writehuman.ai
# Where a client lease lands after the cookie is set. Adjust to WriteHuman's logged-in
# humanizer/dashboard path if "/" does not land there (e.g. /dashboard or /app).
DEFAULT_PATH=/
# Where an admin CAPTURE lease lands to log in fresh and save a session to the vault.
SIGNIN_PATH=/login

GATEWAY_PUBLIC_ORIGIN=https://writehuman1.genzdigitalstore.com
API_BASE=https://api.genzdigitalstore.com/api/crm/proxy/gateway

# MUST match the backend values exactly (same shared pair as the other proxy tools —
# copy from the API app's .env or any existing proxy gateway's env vars):
LEASE_SECRET=__SET_TO_BACKEND_PROXY_LEASE_SECRET__
GATEWAY_KEY=__SET_TO_BACKEND_PROXY_GATEWAY_KEY__

# If WriteHuman serves CSS/JS from a separate CDN/asset host that fails to load
# cross-origin, proxy it same-origin through the gateway, e.g.:
# ASSET_ORIGINS=https://cdn.writehuman.ai
# Keep IDENTITY_SHIELD unset unless proven auth-safe (it can log token SPAs out).
