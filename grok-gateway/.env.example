# ── Grok gateway (deploy on grok1.genzdigitalstore.com) ───────────────────────
# Copy to `.env` on the Grok gateway app (or set these as SetEnv in the subdomain's
# public_html/.htaccess) and fill the secrets. This is the SAME generic engine as the
# HIX / BypassGPT / ChatGPT gateways (server.js is byte-identical) — only this config
# differs, so Grok stays fully isolated: its own subdomain, its own cookie vault
# (backend scopes ProxyAccount rows by tool=grok), its own lease cookie.
#
# NEVER put real secrets in this .example file — only on the server.

PORT=3000
TOOL_KEY=grok
TOOL_NAME=Grok

# grok.com is the standalone, cookie-session web app (NOT x.com/i/grok). Verify the
# exact logged-in path against the live app before going live — set DEFAULT_PATH to the
# chat surface a valid session lands on.
TARGET_ORIGIN=https://grok.com
DEFAULT_PATH=/chat
# Where an admin CAPTURE lease lands to log in fresh and save a session to the vault.
SIGNIN_PATH=/

GATEWAY_PUBLIC_ORIGIN=https://grok1.genzdigitalstore.com
API_BASE=https://api.genzdigitalstore.com/api/crm/proxy/gateway

# MUST match the backend values EXACTLY (copy from the API app's .env, or from any
# existing *-gateway/.env — every proxy tool shares ONE pair of proxy secrets):
LEASE_SECRET=__SET_TO_BACKEND_PROXY_LEASE_SECRET__
GATEWAY_KEY=__SET_TO_BACKEND_PROXY_GATEWAY_KEY__

# ── Grok-specific notes ───────────────────────────────────────────────────────
# • Cloudflare + Turnstile: grok.com sits behind Cloudflare and shows a Turnstile /
#   Cloudflare challenge on sensitive actions. The gateway pins a fixed browser UA +
#   client-hints (matching the backend verifier) so a cf_clearance cookie captured in
#   the vault stays valid, and renders the REAL challenge for the user to solve
#   manually — it never bypasses or auto-solves it. CAPTURE the session THROUGH this
#   gateway (admin "Capture via proxy") so cf_clearance is minted in the same context.
#   Cloudflare's challenge iframe (challenges.cloudflare.com) is already allowed; if a
#   future build needs the reCAPTCHA-style provider proxied, set CAPTCHA_ORIGINS, e.g.:
#   # CAPTCHA_ORIGINS=https://challenges.cloudflare.com
# • Streaming: Grok replies stream from /rest/app-chat/...; the gateway pipes
#   event-streams through untouched, so streaming chat works.
# • Assets: if grok.com references an absolute CDN/asset host that must load
#   same-origin through the gateway, list it (comma-separated), e.g.:
#   # ASSET_ORIGINS=https://assets.grok.com
# • Keep IDENTITY_SHIELD UNSET (off): Grok is a token/cookie SPA and redacting its
#   session/user API would log it out / render blank. Account/email/plan hiding is done
#   by the injected overlay (overlay.js) client-side + the always-on logout block.
# • SESSION LENGTH (countdown) is controlled by the BACKEND lease, not here — set it
#   per-client in Admin → Proxy Tools → Grok → Client Access, or globally via the
#   backend env GROK_LEASE_MINUTES / PROXY_LEASE_MINUTES (default 30).
# • If Grok blocks reverse-proxy usage or requires an unsupported browser-security flow,
#   the gateway shows a friendly notice/block page instead of a blank screen, and the
#   account verifies as session_expired/unknown — mark it blocked/session_expired in
#   the admin vault. Do NOT attempt to bypass login, captcha, payment or rate limits.

# Cloudflare managed-challenge pass-through. grok.com answers a datacenter IP with a
# Cloudflare "Verifying you are human" 403 whose cf_clearance is bound to the IP+UA that
# solves it — so browser-exported cookies fail here. With this ON, the gateway passes the
# REAL challenge page through to the client to solve in-browser (every request egresses
# this server's single IP+pinned UA, so the cf_clearance Cloudflare mints is valid for the
# proxy) and forwards the browser's Cloudflare cookies upstream alongside the vault
# session. It never bypasses or auto-solves the challenge. Leave OFF for tools that don't
# need it; set =1 for Grok.
CF_CHALLENGE_PASSTHROUGH=1

# Optional: max ms to wait for an upstream response before the friendly retry page.
# UPSTREAM_TIMEOUT_MS=30000
