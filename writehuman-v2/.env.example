# ── WriteHuman V2 — standalone service config (Step 1) ────────────────────────
# Copy to `.env` and fill in. The service is dependency-free (Node 18+) and runs with
# zero installs (JSON store). It is fully ISOLATED from production: own secrets, own
# data store, own port/subdomain. NEVER reuse the production proxy secrets here.

# Port the V2 service listens on (gateway + /v2 API share this port).
WRITEHUMAN_V2_PORT=3100

# Public origin the V2 gateway is reachable at (used for same-origin URL rewriting and the
# lease open URL). In production this is the V2 subdomain, e.g. https://writehuman2.genzdigitalstore.com
WRITEHUMAN_V2_PUBLIC_ORIGIN=

# Upstream tool origin (the real WriteHuman site).
WRITEHUMAN_V2_TARGET_ORIGIN=https://writehuman.ai
WRITEHUMAN_V2_DEFAULT_PATH=/
WRITEHUMAN_V2_SIGNIN_PATH=/signup?mode=login
WRITEHUMAN_V2_TOOL_NAME=WriteHuman

# Client-facing lease length (minutes).
WRITEHUMAN_V2_LEASE_MINUTES=30

# ── Secrets (V2-only; never the production values) ────────────────────────────
# Either set a single base secret to DERIVE the rest, OR set each explicitly. Set them
# explicitly in production. The vault key may be 64 hex chars (32 bytes); if omitted it is
# derived. Keep these out of source control.
WRITEHUMAN_V2_SECRET=
WRITEHUMAN_V2_LEASE_SECRET=
WRITEHUMAN_V2_VAULT_KEY=
WRITEHUMAN_V2_GATEWAY_KEY=
WRITEHUMAN_V2_ADMIN_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# auto = use better-sqlite3 if installed, else JSON file. Force with `sqlite` or `json`.
WRITEHUMAN_V2_STORE=auto
# Optional: override the data directory (defaults to store/data).
# WRITEHUMAN_V2_DATA_DIR=

# ── Supabase (verifier) ───────────────────────────────────────────────────────
# The anon key is PUBLIC (the same key WriteHuman ships to every browser) — not a secret.
WRITEHUMAN_V2_SUPABASE_REF=hicfsbrfkzsxbwayibfm
WRITEHUMAN_V2_SUPABASE_URL=https://hicfsbrfkzsxbwayibfm.supabase.co
# WRITEHUMAN_V2_SUPABASE_ANON_KEY=  # only if WriteHuman rotates the public anon key
