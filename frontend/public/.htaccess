DirectoryIndex index.html

# Always revalidate the HTML shell so new deploys appear immediately and a stale
# cached index.html can never produce an old/blank page. Hashed JS/CSS keep their
# own long-lived caching via their unique per-build filenames.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

RewriteEngine On
RewriteBase /

# Serve existing static files directly
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteRule ^login$ https://app.genzdigitalstore.com/client/login [R=302,L]

RewriteCond %{REQUEST_URI} ^/client/
RewriteRule ^ https://app.genzdigitalstore.com%{REQUEST_URI} [R=302,L]

RewriteCond %{REQUEST_URI} ^/admin/
RewriteRule ^ https://app.genzdigitalstore.com%{REQUEST_URI} [R=302,L]

# Route to React SPA — but NOT for /api/ routes (let Passenger handle those)
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
