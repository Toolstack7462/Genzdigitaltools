# ── BypassGPT gateway (deploy on bypassgpt1.genzdigitalstore.com) ─────────────
# Copy to .env and fill the two secrets. Everything else has a working default
# baked into server.js, so you only NEED the secrets.
#
# Never commit the real .env — only this .env.example is tracked.

PORT=3000
TOOL_KEY=bypassgpt
TOOL_NAME=BypassGPT

# Upstream (defaults baked in; override only if needed):
BYPASSGPT_TARGET_ORIGIN=https://www.bypassgpt.ai
BYPASSGPT_DEFAULT_PATH=/ai-humanizer
# Where an admin "capture" lease lands to log in fresh:
SIGNIN_PATH=/sign-in

GATEWAY_PUBLIC_ORIGIN=https://bypassgpt1.genzdigitalstore.com
API_BASE=https://api.genzdigitalstore.com/api/crm/proxy/gateway

# REQUIRED — must match the backend exactly:
LEASE_SECRET=__SET_TO_BACKEND_PROXY_LEASE_SECRET__
GATEWAY_KEY=__SET_TO_BACKEND_PROXY_GATEWAY_KEY__
