{
  "manifest_version": 3,
  "name": "Gen Z Digital Store Access",
  "short_name": "GZDS",
  "version": "3.9.0",
  "description": "Background helper for Gen Z Digital Store. Opens assigned tools with fresh authorized sessions from the member dashboard.",
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "tabs",
    "scripting",
    "notifications",
    "management"
  ],
  "optional_permissions": [
    "activeTab"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://genzdigitalstore.com/*",
        "https://app.genzdigitalstore.com/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "js/bridge.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gen Z Digital Store",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://genzdigitalstore.com/*",
      "https://app.genzdigitalstore.com/*",
      "http://localhost:3000/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "js/strategies/*.js",
        "js/config/*.js",
        "js/core/*.js"
      ],
      "matches": [
        "chrome-extension://*/*"
      ]
    }
  ],
  "host_permissions": [
    "https://genzdigitalstore.com/*",
    "https://app.genzdigitalstore.com/*",
    "https://api.genzdigitalstore.com/*",
    "https://hix.ai/*",
    "https://*.hix.ai/*",
    "http://*/*",
    "https://*/*"
  ]
}