# ============================================================
# Gen Z Digital Store CRM — MySQL/MariaDB Environment Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# --- MySQL / MariaDB ---
# Hostinger example format:
# DATABASE_URL=mysql://u123456789_genz:STRONG_PASSWORD@localhost:3306/u123456789_genz_crm
DATABASE_URL=mysql://user:password@localhost:3306/genz_digital_tools_crm
MYSQL_CONNECTION_LIMIT=10

# --- JWT Secrets (minimum 32 characters each) ---
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<replace-with-random-64-hex-chars>
JWT_REFRESH_SECRET=<replace-with-random-64-hex-chars>
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# --- Cookie/Session Encryption Key (must be exactly 64 hex chars = 32 bytes) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIES_ENCRYPTION_KEY=<replace-with-64-hex-chars>

# --- Session Lifetime ---
# How long admin/client dashboard sessions stay alive (refresh token lifetime).
DASHBOARD_SESSION_DAYS=30

# --- Extension Token Lifetime ---
# How many days an extension token remains valid before re-pairing is required.
EXTENSION_TOKEN_DAYS=365

# --- Device Binding ---
# DEVICE_BINDING_MODE: "soft" (default) — allow new devices silently up to MAX_BROWSER_BINDINGS_PER_CLIENT
#                      "hard" — reject any device not previously registered
DEVICE_BINDING_MODE=soft
MAX_BROWSER_BINDINGS_PER_CLIENT=3
# Set to "true" to require admin approval when a new device exceeds the limit (soft mode only)
REQUIRE_ADMIN_APPROVAL_FOR_NEW_DEVICE=false

# --- Initial Admin Credentials ---
# These are used ONLY on first startup to create the bootstrap admin.
# Change the password immediately after first login.
INITIAL_ADMIN_EMAIL=admin@genzdigitalstore.com
INITIAL_ADMIN_PASSWORD=<replace-with-strong-password>
INITIAL_ADMIN_NAME=Super Admin

# --- CORS Allowed Origins (comma-separated, exact URLs only) ---
# Example: https://genzdigitalstore.com,https://app.genzdigitalstore.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Server Ports ---
CRM_PORT=8002
PORT=8001

# --- Node Environment ---
NODE_ENV=development
