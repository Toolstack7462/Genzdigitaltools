# StealthWriter Proxy Gateway — environment (deploy on stealth1.genzdigitalstore.com)
# Copy to .env and fill in. NEVER commit the real .env.

# Port the gateway listens on. Hostinger/Passenger injects PORT automatically;
# server.js falls back to 3000 locally if PORT is unset.
PORT=3000

# The real StealthWriter origin to reverse-proxy. Scheme + host ONLY (no path, no trailing slash).
STEALTH_TARGET_ORIGIN=https://stealthwriter.ai

# Landing path after the lease cookie is set — open the authenticated humanizer
# dashboard directly (not the marketing root, which bounces to /sign-in).
STEALTH_DEFAULT_PATH=/dashboard/humanizer
STEALTH_HUMANIZER_PATH=/dashboard/humanizer
STEALTH_DETECTOR_PATH=/dashboard/ai-detector

# Genz backend gateway API base (the api docroot). Used for authoritative lease
# validation + usage consumption. No trailing slash.
STEALTH_API_BASE=https://api.genzdigitalstore.com/api/crm/stealth/gateway

# Public origin of THIS gateway (used to rewrite upstream redirects). No trailing slash.
GATEWAY_PUBLIC_ORIGIN=https://stealth1.genzdigitalstore.com

# MUST match the backend's STEALTH_LEASE_SECRET so the gateway can verify lease
# signatures locally. Min 32 chars. If the backend derives its key from JWT_SECRET
# (no dedicated secret set there), set the SAME dedicated secret on BOTH sides.
STEALTH_LEASE_SECRET=

# Account Vault: shared key for the backend /session endpoint that returns the
# decrypted account session bundle (server-to-server only). MUST match the
# backend's STEALTH_GATEWAY_KEY. If unset, account-session injection is disabled
# and the gateway proxies without logging in as a vault account.
STEALTH_GATEWAY_KEY=

# Optional. Extra CSS selectors (comma-separated) for StealthWriter's EXACT top-bar
# and bottom account-area containers. They are added to the critical hide CSS that is
# injected into <head> BEFORE the page paints, so those areas never flash. The generic
# rules already hide account/billing/pricing/logout links and avatar/user-menu controls
# by href/aria/data-testid; use this only when StealthWriter wraps the top bar or the
# bottom sidebar account block in an obfuscated class you want gone completely.
# Do NOT include selectors that would match the editor / Humanize / Check-for-AI area.
# Example:
#   STEALTH_HIDE_SELECTORS=header.app-topbar, aside .sidebar-footer, .account-widget
STEALTH_HIDE_SELECTORS=
