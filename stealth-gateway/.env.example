# StealthWriter Proxy Gateway — environment (deploy on stealth1.genzdigitalstore.com)
# Copy to .env and fill in. NEVER commit the real .env.

# Port the gateway listens on (Hostinger/Passenger sets this automatically).
PORT=8080

# The real StealthWriter origin to reverse-proxy. Scheme + host only, no trailing slash.
STEALTH_TARGET_ORIGIN=https://app.stealthwriter.ai

# Genz backend gateway API base (the api docroot). Used for authoritative lease
# validation + usage consumption. No trailing slash.
STEALTH_API_BASE=https://api.genzdigitalstore.com/api/crm/stealth/gateway

# Public origin of THIS gateway (used to rewrite upstream redirects). No trailing slash.
GATEWAY_PUBLIC_ORIGIN=https://stealth1.genzdigitalstore.com

# MUST match the backend's STEALTH_LEASE_SECRET so the gateway can verify lease
# signatures locally. Min 32 chars. If the backend derives its key from JWT_SECRET
# (no dedicated secret set there), set the SAME dedicated secret on BOTH sides.
STEALTH_LEASE_SECRET=
